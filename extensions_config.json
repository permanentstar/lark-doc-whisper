      "description": "Official GitHub MCP remote server, restricted to all read-only GitHub tools."
    }
  },
  "mcpInterceptors": [
    "lark_doc_whisper.agent.github_mcp_policy:build_github_mcp_interceptor"
  ],
  "skills": {}
}
